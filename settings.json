// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "inlay_hints": {
    "enabled": true
  },
  "lsp_document_colors": "background",
  "ui_font_weight": 400.0,
  "colorize_brackets": true,
  "tabs": {
    "git_status": true,
    "file_icons": true
  },
  "git_panel": {
    "show_count_badge": true,
    "tree_view": true,
    "file_icons": true,
    "status_style": "label_color"
  },
  "soft_wrap": "editor_width",
  "buffer_font_weight": 350.0,
  "title_bar": {
    "show_branch_status_icon": false,
    "show_onboarding_banner": true
  },
  "sticky_scroll": {
    "enabled": true
  },
  "prettier": {
    "allowed": true
  },
  "tab_size": 2,
  "indent_guides": {
    "coloring": "indent_aware",
    "line_width": 1,
    "active_line_width": 2,
    "background_coloring": "disabled"
  },
  "scrollbar": {
    "axes": {
      "vertical": false,
      "horizontal": true
    },
    "show": "auto"
  },
  "terminal": {
    "scrollbar": {
      "show": "system"
    },
    "cursor_shape": "bar",
    "blinking": "on"
  },
  "minimap": {
    "thumb_border": "left_open",
    "thumb": "always",
    "max_width_columns": 45,
    "show": "auto"
  },
  "code_lens": "on",
  "languages": {
    "TypeScript": {
      "inlay_hints": {
        "enabled": true
      }
    }
  },
  "vim_mode": true,
  "vim": {
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true
  },
  "relative_line_numbers": "enabled",
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "agent_servers": {
    "qoder": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },

  "language_models": {
    "opencode": {
      "show_zen_models": false
    }
  },
  "base_keymap": "Cursor",
  "icon_theme": {
    "mode": "dark",
    "light": "Warm Charmed Icons",
    "dark": "Warm Charmed Icons"
  },
  "ui_font_family": "MonoLisa",
  "buffer_line_height": "standard",
  "buffer_font_family": "MonoLisa",
  "outline_panel": {
    "dock": "left"
  },
  "project_panel": {
    "git_status": true,
    "git_status_indicator": true,
    "bold_folder_labels": false,
    "indent_size": 14.0,
    "dock": "left",
    "entry_spacing": "standard",

    "file_icons": true,
    "folder_icons": true,
    "auto_reveal_entries": true
  },
  "agent": {
    "show_turn_stats": true,
    "dock": "right",
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": [],
    "tool_permissions": {
      "tools": {
        "move_path": {
          "default": "confirm"
        },
        "copy_path": {
          "default": "allow"
        },
        "write_file": {
          "default": "allow"
        },
        "edit_file": {
          "default": "allow"
        },
        "fetch": {
          "default": "allow"
        },
        "search_web": {
          "default": "allow"
        }
      },
      "default": "confirm"
    },
    "default_profile": "write",
    "default_model": {
      "effort": "max",
      "enable_thinking": true,
      "provider": "opencode",
      "model": "go/deepseek-v4-flash"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "ui_font_size": 15.5,
  "buffer_font_size": 16.0,
  "agent_buffer_font_size": 15.0,
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Tokyo Night"
  },
  // === Which Key (shows leader hints) ===
  "which_key": {
    "enabled": true
  },
  // === Telemetry ===
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
