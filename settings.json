// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
// ~/.config/zed/settings.json
{
  // === Theme & Appearance ===
  "semantic_tokens": "combined",
  "languages": {
    "TypeScript": {
      "document_folding_ranges": "off",
      "colorize_brackets": true,
      "inlay_hints": {
        "show_background": false,
        "show_other_hints": true,
        "show_type_hints": true,
        "show_value_hints": true,
        "enabled": true
      },
      "indent_guides": {
        "coloring": "indent_aware",
        "line_width": 2,
        "active_line_width": 1,
        "background_coloring": "disabled"
      }
    },
    "TSX": {
      "inlay_hints": { "enabled": true, "show_background": false },
      "colorize_brackets": true
    },
    "JavaScript": {
      "inlay_hints": { "enabled": true, "show_background": false },
      "colorize_brackets": true
    },
    "Markdown": {
      "soft_wrap": "editor_width",
      "show_edit_predictions": false
    }
  },
  // TypeScript LSP — show hints only when useful, not on obvious inferred types
  "lsp": {
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          // param names: only on literals (not when arg name == param name)
          "includeInlayParameterNameHints": "literals",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": false,
          // don't show variable types when TS can obviously infer them
          "includeInlayVariableTypeHints": false,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          // function param types — off, too noisy
          "includeInlayFunctionParameterTypeHints": false,
          // return types — on, useful to see without hovering
          "includeInlayFunctionLikeReturnTypeHints": true,
          // property types in class/object — off, inferred by TS
          "includeInlayPropertyDeclarationTypeHints": false,
          // enum values — on, very useful
          "includeInlayEnumMemberValueHints": true
        }
      }
    }
  },
  "notification_panel": {
    "show_count_badge": true
  },
  "agent_buffer_font_size": 15.0,
  "ui_font_family": "MonoLisa",
  "buffer_line_height": "standard",
  "agent_servers": {
    "factory-droid": {
      "type": "registry"
    },
    "qoder": {
      "type": "registry"
    },
    "pi-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    },
    "kimi": {
      "type": "registry"
    },
    "junie": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "outline_panel": {
    "button": false,
  },
  "search": {
    "button": true,
  },
  "title_bar": {
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": true,
    "show_sign_in": true,
    "show_user_menu": true,
    "show_user_picture": true,
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Mocha",
    "dark": "NvChad Rxyhn Theme",
  },
  "icon_theme": "Catppuccin Mocha",
  "buffer_font_family": "MonoLisa",
  "buffer_font_size": 16.0,
  "buffer_font_weight": 450.0,
  "ui_font_size": 15.0,
  "agent_ui_font_size": 16.0,

  // === Vim ===
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    // "enable_vim_sneak": true,
    "gdefault": false,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 200,
    "use_regex_search": true,
  },
  "current_line_highlight": "all",
  "relative_line_numbers": "enabled",
  "base_keymap": "Cursor",

  // === Which Key (shows leader hints) ===
  "which_key": {
    "enabled": true,
  },

  // === Layout ===
  "project_panel": {
    "button": true,
    "dock": "left",
    "indent_size": 20.0,
    "entry_spacing": "standard",
  },
  "git_panel": { "dock": "right" },
  "tab_bar": {
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": true,
    "show": true,
  },
  "scrollbar": { "show": "never" },
  "minimap": {
    "show": "auto",
    "current_line_highlight": "all",
    "max_width_columns": 55,
    "thumb": "always",
    "thumb_border": "left_open",
  },
  "tabs": { "show_diagnostics": "errors" },
  "indent_guides": { "enabled": true, "coloring": "indent_aware" },

  // === Editor ===
  "format_on_save": "on",
  "soft_wrap": "editor_width",
  "cursor_blink": true,
  "show_whitespaces": "boundary",
  "inlay_hints": { "enabled": true },
  "linked_edits": true,
  "colorize_brackets": true,
  "remove_trailing_whitespace_on_save": true,
  "show_edit_predictions": true,

  // === Prettier ===
  "prettier": { "allowed": true },

  // === Terminal ===
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "shell": { "program": "zsh" },
    "font_family": "MonoLisa",
    "font_size": 15.0,
    "blinking": "on",
    "dock": "bottom",
  },

  // === Git ===
  "git": {
    "inline_blame": { "enabled": true },
  },

  // === AI ===
  "agent": {
    "tool_permissions": {
      "tools": {
        "create_directory": {
          "default": "allow"
        },
        "terminal": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^wc\\b"
            },
            {
              "pattern": "^cat\\s+test\\.txt(\\s|$)"
            },
            {
              "pattern": "^find\\s+\\.(\\s|$)"
            }
          ]
        },
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://github\\.com"
            }
          ]
        }
      }
    },
    "default_profile": "ask",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
  },

  // === File types ===
  "file_types": {
    "JSONC": ["tsconfig.json", "tsconfig.*.json", ".prettierrc"],
  },

  // === Telemetry ===
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
