[
  {
    "label": "lazygit",
    "command": "lazygit",
    "args": ["-p", "$ZED_WORKTREE_ROOT"],
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "on_success",
    "save": "none",
  },
  {
    "label": "dev (bun)",
    "command": "bun",
    "args": ["run", "dev"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
    "save": "all",
  },
  {
    "label": "test (bun)",
    "command": "bun",
    "args": ["run", "test"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "build (bun)",
    "command": "bun",
    "args": ["run", "build"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "typecheck (bun)",
    "command": "bun",
    "args": ["run", "typecheck"],
    "cwd": "$ZED_WORKTREE_ROOT",
